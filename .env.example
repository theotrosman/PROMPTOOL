# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Evaluation (Groq or compatible)
# WARNING: VITE_ prefix exposes this to the client bundle.
# For production, move AI calls to a server-side API route.
VITE_GROQ_API_KEY=your-groq-api-key-here
VITE_AI_EVAL_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# Image proxy (optional)
VITE_IMG_PROXY_URL=/api/img-proxy

# Supabase service key (server-side only, never expose to client)
# Used only in vite.config.js for dev image caching
SUPABASE_SERVICE_KEY=your-service-role-key-here
