{
  "trailingSlash": false,
  "routes": [
    { "src": "^/user/(.*)$", "dest": "/user.html" },
    { "src": "^/admin$", "dest": "/admin.html" },
    { "src": "^/leaderboard$", "dest": "/leaderboard.html" },
    { "src": "^/tournaments$", "dest": "/tournaments.html" },
    { "src": "^/guides$", "dest": "/guides.html" },
    { "src": "^/support$", "dest": "/support.html" },
    { "src": "^/terms$", "dest": "/terms.html" },
    { "src": "^/privacy$", "dest": "/privacy.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
